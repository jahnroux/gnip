releases/*.msi

# SQLite data + WAL sidecars
*.db
*.db-wal
*.db-shm

# Logs
*.log

# Runtime settings (environment-specific; created at runtime)
gnip.settings.json

# IDE
.vs/
.idea/
*.user

# Claude Code local settings (machine-specific permissions/paths)
.claude/
